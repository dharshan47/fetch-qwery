{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "fetch-qwery": ["./package/src/index.ts"]
    }
  },
  "include": ["package/src/**/*", "test/**/*", "demo/**/*"],
  "exclude": ["node_modules", "dist"]
}

